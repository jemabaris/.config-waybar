* {
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 0px;
  font-family: JetBrainsMono Nerd Font Propo;
  font-weight: 700;
  font-size: 15px;
}

.modules-center {
  background-color: #1a1a1a;
  border-radius: 28px;
  margin: 16px;
  padding: 6px 12px;
  box-shadow: 0px 6px 8px rgba(0, 0, 0, 0.9);
}

window#waybar {
  background: transparent;
}

#custom-launcher {
  font-size: 20px;
  color: #00bfff;
  padding-right: 10px;
  background-color: #1a1c2b;
}

